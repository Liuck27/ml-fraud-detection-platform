# =============================================================================
# ML Fraud Detection Platform — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=fraud_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full DSN (used by SQLAlchemy-based services)
DATABASE_URL=postgresql://fraud_user:change_me_postgres@postgres:5432/fraud_db

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=postgresql://fraud_user:change_me_postgres@postgres:5432/mlflow_db
MLFLOW_ARTIFACT_ROOT=./mlartifacts
MLFLOW_PORT=5000

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://fraud_user:change_me_postgres@postgres:5432/airflow_db
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=change_me_generate_with_fernet
AIRFLOW__WEBSERVER__SECRET_KEY=change_me_webserver_secret
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW_UID=50000
AIRFLOW_PORT=8080

# ── FastAPI Serving ───────────────────────────────────────────────────────────
SERVING_PORT=8000
SERVING_WORKERS=1
AB_CHALLENGER_FRACTION=0.20
MODEL_CHAMPION_ALIAS=champion
MODEL_CHALLENGER_ALIAS=challenger
MODEL_XGBOOST_NAME=fraud-xgboost
MODEL_AUTOENCODER_NAME=fraud-autoencoder

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_DAYS=15

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_grafana

# ── Evidently ─────────────────────────────────────────────────────────────────
EVIDENTLY_REFERENCE_DATA_PATH=/app/data/processed/reference.parquet
EVIDENTLY_REPORTS_PATH=/app/data/reports

# ── Kaggle (for data download script) ────────────────────────────────────────
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
